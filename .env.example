# Blinsky Voice Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Phase 1 — Core ────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_key_here        # Required for web search. Free at tavily.com
OLLAMA_BASE_URL=http://ollama:11434  # use this when running in docker
# OLLAMA_BASE_URL=http://localhost:11434  # use this when running locally
OLLAMA_MODEL=qwen2.5:7b                    # LLM model. Run: ollama pull qwen2.5:7b

# ── Phase 2 — Wake Word (Porcupine) ───────────────────────────────────────────
# Get your free AccessKey at https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here
# Built-in keywords (free): blueberry, bumblebee, alexa, jarvis, computer,
#   hey siri, hey google, ok google, picovoice, porcupine
WAKE_WORD_KEYWORD=blueberry
WAKE_WORD_SENSITIVITY=0.5

# ── Phase 3 — Telegram Bot ────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, copy the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
